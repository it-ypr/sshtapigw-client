  public static function queryConditionSimrs(string $tgl_param, string $rm, string $dok, string $poli_idihs)
  {
    $dbSimrs = Yii::$app->db;

    return (new Query())
      ->select(['k.Id', 'k.rm', 'k.icd', 'k.dok', 'k.poli', 'mpoli.idssht'])
      ->from('mr_kunjungan k')
      ->leftJoin('mpoli', 'k.poli = mpoli.poli')
      ->where([
        'k.rm' => $rm,
        'k.dok' => $dok,
        'k.tanggal' => $tgl_param,
        'mpoli.idssht' => $poli_idihs,
      ])
      ->orderBy("Id ASC")
      ->all($dbSimrs);
  }

  // query-observation-diagnosticreport RAD
  // observation & diagnostic report RAD
  public static function queryObservationDanDiagnosticReportSimrsRadio(string $noradio)
  {
    $dbSimrs = Yii::$app->db; // dbSimrs

    return (new Query())
      ->select(['b.rm', 'h.hasil'])
      ->from('rd_hasil h')
      ->leftJoin('rd_biodata b', 'h.noradio = b.noradio')
      ->where(['h.noradio' => $noradio, 'h.ondelete' => 0])
      ->one($dbSimrs);
  }

  /**
   * Query lokal observation rawat jalan
   * @param string $tanggal
   */
  public static function queryObservationRalan(string $tanggal, string $rm)
  {
    $db1 = Yii::$app->db;

    $result = (new Query())
      ->select([
        't1.Id',
        't1.rm',
        't2.nama',
        't1.tanggal',
        't1.dokter',
        't1.poli',
        't3.rl_user',
        't1.jenis',
        't1.textisi',
      ])
      ->from(['t1' => 'mr_medis_rtf'])
      ->leftJoin(['t2' => 'mmr'], 't1.rm = t2.rm')
      ->leftJoin(['t3' => 'muser'], 't1.dokter = t3.id_user')
      ->where([
        't1.tanggal' => $tanggal,
        't1.rm' => $rm,
        't1.jenis' => 'KO'
      ])
      ->one($db1);

    if (!$result) {
      return false;
    }

    $data['tanggal'] = $result['tanggal'];
    $data['rm'] = $result['rm'];
    $data['nama'] = $result['nama'];
    $data['kode_dokter'] = $result['dokter'];
    $data['nama_dokter'] = $result['rl_user'];
    $data['jenis'] = $result['jenis'];
    $data['poli'] = $result['poli'];

    // parse kolom texisi
    // $data['td_sistolik'] = $result['dsfasdfad'];
    // $data['td_diastolik'] = $result['dsfasdfad'];
    // $data['suhu_tubuh'] = $result['dsfasdfad'];
    // $data['denyut_jantung'] = $result['dsfasdfad'];
    // $data['pernafasan'] = $result['dsfasdfad'];
    $data['observation_data'] = SshtApiUtil::parseObservation($result['textisi']);

    return $data;
  }

  public static function queryProcedureGeneral(string $tanggal, string $rm)
  {
    $db1 = Yii::$app->db;
    $result = (new Query())
      ->select([
        't2.tanggal',
        't2.rm',
        't3.nama',
        't1.id_casemix',
        't2.Id',
        't1.kode_icd',
        't1.procedure',
        't2.dokter',
        't4.rl_user',
        't2.poli',
      ])
      ->from(['t1' => 'mr_casemix_ralan_pc'])
      ->leftJoin(['t2' => 'mr_casemix_ralan'], 't1.id_casemix = t2.Id')
      ->leftJoin(['t3' => 'mmr'], 't2.rm = t3.rm')
      ->leftJoin(['t4' => 'muser'], 't2.dokter = t4.id_user')
      ->where([
        't2.tanggal' => $tanggal,
        't2.rm' => $rm,
      ])
      ->all($db1);

    if (!$result) {
      return false;
    }

    $first = $result[0];
    $procedures = [];
    $seen = [];

    foreach ($result as $row) {
      $icd9 = trim((string) $row['kode_icd']);
      $desc = trim((string) $row['procedure']);
      $key = $icd9 . "\0" . $desc;

      if (isset($seen[$key])) {
        continue;
      }

      $seen[$key] = true;
      $procedures[] = [
        'icd9' => $icd9,
        'desc' => $desc,
      ];
    }

    $data['tanggal'] = $first['tanggal'];
    $data['rm_pasien'] = $first['rm'];
    $data['nama_pasien'] = $first['nama'];
    $data['kode_dokter'] = $first['dokter'];
    $data['nama_dokter'] = $first['rl_user'];
    $data['procedures'] = $procedures;
    $data['kode_poli'] = $first['poli'];

    return $data;
  }

  public static function queryLabRalan(string $tanggal, string $rm)
  {
    $db1 = Yii::$app->db;

    // select lnb.tanggal, lnb.rm, 
    // lis_hasil.*,
    // lab_transaksi.notest,
    // lab_transaksi.kode_trn, 
    // harga_laborat.nama, 
    // lab_transaksi.jenis_trn 
    // from ( 
    //   select lab_newbiodata.*
    //   from lab_newbiodata
    //   where lab_newbiodata.rm = '320904' and lab_newbiodata.tanggal = '2025-09-29'
    // ) as lnb
    // left join lis_hasil on lnb.NoTest = lis_hasil.SAMPEL_ID
    // left join lab_product on lis_hasil.TEST_ID = lab_product.id_lab
    // left join lab_transaksi on lnb.NoTest = lab_transaksi.notest
    // left join harga_laborat on lab_transaksi.kode_trn = harga_laborat.test_id;

    $sub = (new Query())
      ->select('*')
      ->from('lab_newbiodata')
      ->where([
        'rm' => '320904',
        'tanggal' => '2025-09-29',
      ]);

    $query = (new Query())
      ->select([
        'lnb.tanggal',
        'lnb.rm',
        'lis_hasil.*',
        'lab_transaksi.notest',
        'lab_transaksi.kode_trn',
        'harga_laborat.nama',
        'lab_transaksi.jenis_trn',
      ])
      ->from(['lnb' => $sub])
      ->leftJoin('lis_hasil', 'lnb.NoTest = lis_hasil.SAMPEL_ID')
      ->leftJoin('lab_product', 'lis_hasil.TEST_ID = lab_product.id_lab')
      ->leftJoin('lab_transaksi', 'lnb.NoTest = lab_transaksi.notest')
      ->leftJoin('harga_laborat', 'lab_transaksi.kode_trn = harga_laborat.test_id');

    $data = $query->all($db1);

    if (!$data) {
      return false;
    }

    return $data;
  }

  public static function queryMedicationRalan(string $tgl_param, string $rm_param)
  {
    $db1 = Yii::$app->db;

    $sub = (new Query())
      ->select([
        'fb.Id',
        'fb.tanggal',
        'fb.resep',
        'fb.nama',
        'fb.rm',
        'fb.kddokter',
        'fb.petugas',
        'fb.id_ambil',
      ])
      ->from(['fb' => 'frm_biodata'])
      ->where([
        'fb.tanggal' => $tgl_param
      ]);

    $query = (new Query())
      ->select([
        'fr.Id',
        'fbio.resep',
        'fbio.rm',
        'fbio.tanggal',
        'fbio.kddokter',
        'fr.resep as fr_resep',
        'rob.id_local',
        'lg.kode_brg',
        'lg.nama',
        'rob.kfa_code',
        'rob.kfa_display',
        'fr.jumlah',
        'fr.kali',
        'fr.hari',
        'rob.kfa_bza',
        'rob.kfa_ucum',
        'rob.kfa_uom',
        'rob.kfa_route',
        'rob.kfa_form',
        'md.idssht as ihs_dok',
        'mp.idssht as ihs_petugas',
        'mp.nm_user as petugas_nama',
        'ma.idssht as ihs_petugas_ambil',
        'ma.nm_user as petugas_ambil_nama'
      ])
      ->from(['fbio' => $sub])
      ->leftJoin('frm_ralan as fr', 'fbio.resep = fr.resep and fbio.tanggal = fr.tanggal')
      ->leftJoin('log_gudang as lg', 'fr.kode_brg = lg.kode_brg')
      ->leftJoin('ref_obat_briging as rob', 'lg.Id = rob.id_local')
      ->leftJoin('muser as md', 'fbio.kddokter = md.nik')
      ->leftJoin('muser as mp', 'fbio.petugas = mp.nik')
      ->leftJoin('muser as ma', 'fbio.id_ambil = ma.nik')
      ->where(['fbio.rm' => $rm_param]);

    $data = $query->all($db1);

    if (!$data) {
      return false;
    }

    return $data;
  }


  public static function getRefObatByLocalId(string $localid)
  {
    $db1 = Yii::$app->db;

    $result = (new Query())
      ->select([
        'rob.Id',
        'rob.id_local',
        'rob.kfa_code',
        'rob.kfa_display',
        'rob.kfa_bza',
        'rob.kfa_form',
        'rob.kfa_route'
      ])
      ->from(['rob' => 'ref_obat_briging'])
      ->where([
        'rob.id_local' => $localid,
      ])
      ->one($db1);

    if (!$result) {
      return false;
    }

    return $result;
  }
}

